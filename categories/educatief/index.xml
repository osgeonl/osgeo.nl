&lt;a href=&#34;http://osgeonl.github.io/sitecontent/events/nieuwjaarsborrel2015/presentaties/OpenTopo_1600px_issues_JW_van_Aalst.pdf&#34; target=&#34;_blank&#34;&gt;&lt;em&gt;&lt;strong&gt;&lt;img loading=&#34;lazy&#34; class=&#34;  wp-image-719 alignleft&#34; src=&#34;/photos/2015/01/jw-slide.png&#34; alt=&#34;jw-slide&#34; width=&#34;289&#34; height=&#34;194&#34; srcset=&#34;/photos/2015/01/jw-slide.png 420w, /photos/2015/01/jw-slide-300x201.png 300w, /photos/2015/01/jw-slide-223x150.png 223w, /photos/2015/01/jw-slide-150x101.png 150w&#34; sizes=&#34;(max-width: 289px) 100vw, 289px&#34; /&gt;&lt;/strong&gt;&lt;/em&gt;&lt;/a&gt;
--&gt;

&lt;div class=&#34;float_left&#34;&gt;
  &lt;a href=&#34;http://osgeonl.github.io/sitecontent/events/nieuwjaarsborrel2015/presentaties/OpenTopo_1600px_issues_JW_van_Aalst.pdf&#34;&gt;
    &lt;img class=&#34;lazy&#34;
      src=&#34;/photos/2015/01/jw-slide.png&#34;
      alt=&#34; &#34; /&gt;
  &lt;/a&gt;
  
&lt;/div&gt;

&lt;p&gt; &lt;/p&gt;
&lt;p&gt; &lt;/p&gt;
&lt;p&gt;&lt;em&gt;&lt;strong&gt;Jan-Willem van Aalst&lt;/strong&gt;&lt;/em&gt; presenteerde &lt;a href=&#34;http://osgeonl.github.io/sitecontent/events/nieuwjaarsborrel2015/presentaties/OpenTopo_1600px_issues_JW_van_Aalst.pdf&#34;&gt;OpenTopo op 1600px/km – Voortgang en Issues&lt;/a&gt;. Wat kom je allemaal tegen als je BAG/OSM en Top10NL combineert in toenemend detail.&lt;/p&gt;
          
          
        
